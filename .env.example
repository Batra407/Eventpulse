# ════════════════════════════════════════════════════════════════
#  EventPulse — Environment Variables Template
#  Copy this file to .env and fill in real values before running.
#  NEVER commit the real .env to version control.
# ════════════════════════════════════════════════════════════════

# ── Server ───────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development          # Change to: production

# ── MongoDB ──────────────────────────────────────────────────────
# Local standalone (dev/test):
MONGO_URI=mongodb://localhost:27017/eventpulse
# MongoDB Atlas (staging/production) — replace placeholders:
# MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/eventpulse?retryWrites=true&w=majority

# ── JWT ──────────────────────────────────────────────────────────
# Generate with:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_HEX_STRING
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── CORS ─────────────────────────────────────────────────────────
# Must match the deployed frontend URL exactly (no trailing slash)
FRONTEND_ORIGIN=https://your-app.vercel.app

# ── Super Admin (seed once) ───────────────────────────────────────
# Run:  node scripts/seedSuperAdmin.js  (only once, after deployment)
SUPER_ADMIN_EMAIL=admin@yourdomain.com
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_PASSWORD=CHANGE_ME_min_8_chars_must_be_strong

# ── Email / SMTP (Nodemailer) ─────────────────────────────────────
# Gmail: Account → Security → 2-Step Verification → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password_here
EMAIL_FROM="EventPulse <your_gmail@gmail.com>"
